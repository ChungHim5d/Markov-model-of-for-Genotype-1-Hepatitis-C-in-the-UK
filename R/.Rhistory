tab_header(
title = md("**Table 1. Model parameters for transition rates, treatment efficacy, health utilities and health-state costs**")
) %>%
cols_label(
Treatment = "",
From = "From / health state",
To = "To",
Mean = "Mean",
Distribution = "Distribution",
Source = "Source"
) %>%
tab_options(
table.font.size = px(12),
heading.title.font.size = px(14),
heading.title.font.weight = "bold",
column_labels.font.weight = "bold",
table.width = pct(100),
# This controls the grey subsection rows
row_group.background.color = "#E6E6E6",
row_group.font.weight = "bold",
row_group.font.size = px(12),
# Keep normal body rows white
data_row.padding = px(5)
) %>%
# Make normal column headers white
tab_style(
style = cell_fill(color = "white"),
locations = cells_column_labels()
) %>%
# Make all normal body rows white
tab_style(
style = cell_fill(color = "white"),
locations = cells_body()
) %>%
# Make only the subsection/group headers grey
tab_style(
style = list(
cell_fill(color = "#E6E6E6"),
cell_text(weight = "bold")
),
locations = cells_row_groups()
)
) %>%
model_params %>%
mutate(
Section = case_when(
Section == "Transition probabilities" ~ "Transition probabilities",
Section %in% c("Treatment efficacy: DAA", "Treatment efficacy: PR") ~ "Treatment efficacy (in probability)",
Section == "Health-state utilities" ~ "Health States Utilities",
Section == "Health-state costs" ~ "Health States Costs (Adjusted) in £",
TRUE ~ Section
),
Treatment = case_when(
str_detect(Section, "Treatment efficacy") & From %in% c("Mild HCV", "Moderate HCV", "Compensated cirrhosis") &
Source == "WHO (2016)" ~ "DAA Treatment",
str_detect(Section, "Treatment efficacy") & Source == "Bruno (2010)" ~ "PR Treatment",
TRUE ~ NA_character_
),
To = replace_na(To, "—"),
Mean = case_when(
Parameter %in% c("Annual cost (£)", "Additional cost (£)") ~
paste0("£", format(round(Mean, 0), big.mark = ",")),
TRUE ~
format(round(Mean, 4), nsmall = 3)
)
) %>%
select(Section, Treatment, From, To, Mean, Distribution, Source) %>%
gt(groupname_col = "Section") %>%
tab_header(
title = md("**Table 1. Model parameters for transition rates, treatment efficacy, health utilities and health-state costs**")
) %>%
cols_label(
Treatment = "",
From = "From / health state",
To = "To",
Mean = "Mean",
Distribution = "Distribution",
Source = "Source"
) %>%
tab_options(
table.font.size = px(12),
heading.title.font.size = px(14),
heading.title.font.weight = "bold",
column_labels.font.weight = "bold",
table.width = pct(100),
# This controls the grey subsection rows
row_group.background.color = "#E6E6E6",
row_group.font.weight = "bold",
row_group.font.size = px(12),
# Keep normal body rows white
data_row.padding = px(5)
) %>%
# Make normal column headers white
tab_style(
style = cell_fill(color = "white"),
locations = cells_column_labels()
) %>%
# Make all normal body rows white
tab_style(
style = cell_fill(color = "white"),
locations = cells_body()
) %>%
# Make only the subsection/group headers grey
tab_style(
style = list(
cell_fill(color = "#E6E6E6"),
cell_text(weight = "bold")
),
locations = cells_row_groups()
)
